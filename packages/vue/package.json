{
  "name": "@vates/data-table-vue",
  "version": "0.1.0",
  "description": "Vue 3 adapter for data-table",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vatesfr/data-table.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "table",
    "datatable",
    "sort",
    "filter",
    "group",
    "vue",
    "vue3",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/data-table-vue.umd.cjs",
  "module": "./dist/data-table-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/data-table-vue.js",
      "require": "./dist/data-table-vue.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vates/data-table-core": "^0.1.0"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.1.9",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
