{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@vates/data-table-core": ["../core/src/index.ts"],
      "@vates/data-table-core/locales": ["../core/src/locales.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
