{
  "name": "@vates/data-table-core",
  "version": "0.1.0",
  "description": "Framework-agnostic core logic for data-table",
  "license": "MIT",
  "author": "Vates",
  "homepage": "https://github.com/vatesfr/data-table/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/vatesfr/data-table/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vatesfr/data-table.git",
    "directory": "packages/core"
  },
  "keywords": [
    "table",
    "datatable",
    "sort",
    "filter",
    "group",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./locales": {
      "import": "./dist/locales.js",
      "require": "./dist/locales.cjs",
      "types": "./dist/locales.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.0.0"
  }
}
